    <command:examples>
      <command:example>
        <maml:title>-------------------------- EXAMPLE 1 --------------------------</maml:title>
        <dev:code>Find-SensitivityLabelsOnFilesInM365 -FileLocation ".\myfiles.txt" -Workloads EXO -UseCachedLabels -ExportResults</dev:code>
        <dev:remarks>
          <maml:para>Reads file names from myfiles.txt, retrieves labels from the active IPPS session, searches Exchange Online, and exports results to CSV.</maml:para>
        </dev:remarks>
      </command:example>
      <command:example>
        <maml:title>-------------------------- EXAMPLE 2 --------------------------</maml:title>
        <dev:code>Find-SensitivityLabelsOnFilesInM365 -TargetFiles "document1.docx", "report.pdf" -Labels "Confidential", "Public" -Workloads EXO</dev:code>
        <dev:remarks>
          <maml:para>Searches for specific files with specific sensitivity labels in Exchange Online.</maml:para>
        </dev:remarks>
      </command:example>
      <command:example>
        <maml:title>-------------------------- EXAMPLE 3 --------------------------</maml:title>
